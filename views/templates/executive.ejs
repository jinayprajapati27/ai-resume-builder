<div class="resume-preview t-executive" style="font-family: 'EB Garamond', serif; padding: 40px; background: white; color: #000;">
    <!-- Header -->
    <div style="text-align: center; margin-bottom: 25px;">
        <h1 style="font-size: 24pt; text-transform: uppercase; margin-bottom: 0; font-weight: 600;"><%= resume.personal.fullName %></h1>
        <div style="font-size: 12pt; margin-bottom: 5px; font-weight: 600;"><%= resume.personal.title || '' %></div>
        <div style="font-size: 10pt;">
            <%= resume.personal.location ? resume.personal.location + ' • ' : '' %>
            <%= resume.personal.email %> • <%= resume.personal.phone %>
        </div>
    </div>

    <!-- Experience -->
    <div class="resume-section">
        <h2 style="font-size: 11pt; border-bottom: 1px solid #000; padding-bottom: 2px; margin-bottom: 10px; text-transform: uppercase; font-weight: 600;">Professional Experience</h2>
        <% resume.experience.forEach(exp => { %>
            <div style="margin-bottom: 15px;">
                <div style="display: flex; justify-content: space-between; font-weight: 600; font-size: 10.5pt;">
                    <span><%= exp.company || exp.organization %></span>
                    <span><%= exp.location || '' %></span>
                </div>
                <div style="display: flex; justify-content: space-between; font-style: italic; font-size: 10pt; margin-bottom: 5px;">
                    <span><%= exp.title || exp.role %></span>
                    <span style="font-style: normal;"><%= exp.date || exp.duration %></span>
                </div>
                <ul style="margin-left: 20px; font-size: 10pt; line-height: 1.3;">
                    <% (Array.isArray(exp.description) ? exp.description : [exp.description]).forEach(p => { %>
                        <li><%= p %></li>
                    <% }) %>
                </ul>
            </div>
        <% }) %>
    </div>

    <!-- Projects -->
    <% if (resume.projects && resume.projects.length) { %>
        <div class="resume-section">
            <h2 style="font-size: 11pt; border-bottom: 1px solid #000; padding-bottom: 2px; margin-bottom: 10px; text-transform: uppercase; font-weight: 600;">Selected Project Experience</h2>
            <% resume.projects.forEach(p => { %>
                <div style="margin-bottom: 10px;">
                    <div style="font-weight: 600; font-size: 10pt;">● <%= p.name || p.title %></div>
                    <ul style="margin-left: 20px; font-size: 10pt; list-style-type: '-' ;">
                        <% (Array.isArray(p.description) ? p.description : [p.description]).forEach(li => { %>
                            <li style="padding-left: 5px;"><%= li %></li>
                        <% }) %>
                    </ul>
                </div>
            <% }) %>
        </div>
    <% } %>

    <!-- Education -->
    <div class="resume-section">
        <h2 style="font-size: 11pt; border-bottom: 1px solid #000; padding-bottom: 2px; margin-bottom: 10px; text-transform: uppercase; font-weight: 600;">Education</h2>
        <% resume.education.forEach(edu => { %>
            <div style="margin-bottom: 10px;">
                <div style="display: flex; justify-content: space-between; font-weight: 600; font-size: 10.5pt;">
                    <span><%= edu.school || edu.university %></span>
                    <span><%= edu.location || '' %></span>
                </div>
                <div style="display: flex; justify-content: space-between; font-style: italic; font-size: 10pt;">
                    <span><%= edu.degree %></span>
                    <span style="font-style: normal;"><%= edu.date || edu.year %></span>
                </div>
            </div>
        <% }) %>
    </div>

    <!-- Additional Info -->
    <div class="resume-section">
        <h2 style="font-size: 11pt; border-bottom: 1px solid #000; padding-bottom: 2px; margin-bottom: 10px; text-transform: uppercase; font-weight: 600;">Additional Information</h2>
        <ul style="margin-left: 20px; font-size: 10pt; line-height: 1.4;">
            <% if (resume.skills) { %>
                <li><strong>Technical Skills:</strong> <%= (Array.isArray(resume.skills) ? resume.skills.join(', ') : resume.skills) %></li>
            <% } %>
            <% if (resume.certifications && resume.certifications.length) { %>
                <li><strong>Certifications:</strong> <%= (Array.isArray(resume.certifications) ? resume.certifications.join(', ') : resume.certifications) %></li>
            <% } %>
        </ul>
    </div>
</div>
