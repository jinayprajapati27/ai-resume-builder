<div class="resume-preview t-modern">
  <div class="resume-header">
    <h1><%= resume.personal.fullName %></h1>
    <div class="resume-contact">
      <%= resume.personal.email %> | <%= resume.personal.phone %>
      <% if (resume.personal.linkedin) { %> | <%= resume.personal.linkedin %> <% } %>
    </div>
  </div>

  <div class="resume-section">
    <h2>Professional Summary</h2>
    <p><%= resume.summary %></p>
  </div>

  <div class="resume-section">
    <h2>Core Skills</h2>
    <p><%= resume.skills.join(' • ') %></p>
  </div>

  <div class="resume-section">
    <h2>Experience</h2>
    <% resume.experience.forEach(exp => { %>
      <div class="resume-item">
        <div class="resume-item-header">
          <span><%= exp.title || exp.role %></span>
          <span><%= exp.date || exp.duration %></span>
        </div>
        <div class="resume-item-sub font-italic"><%= exp.company || exp.organization %></div>
        <ul class="resume-bullets">
          <% (Array.isArray(exp.description) ? exp.description : [exp.description]).forEach(point => { %>
            <li><%= point %></li>
          <% }) %>
        </ul>
      </div>
    <% }) %>
  </div>
</div>
