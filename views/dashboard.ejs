<% 
let dashboardBody = `
    <div class="god-rays"></div>
    <div class="container" style="padding-top: 2rem;">
        <header style="margin-bottom: 3rem; display: flex; justify-content: space-between; align-items: center;">
            <div>
                <h1 style="font-size: 2.5rem; margin-bottom: 0.5rem;">Your <span>Resumes</span></h1>
                <p style="color: var(--text-muted)">Manage and access all your AI-generated resumes</p>
            </div>
        </header>

        <div class="grid-3" id="resumeGrid">`;

if (resumes.length === 0) {
    dashboardBody += `
        <div style="grid-column: 1/-1; text-align: center; padding: 5rem; background: rgba(255,255,255,0.03); border-radius: 1.5rem; border: 1px dashed var(--border);">
            <p style="color: var(--text-muted); font-size: 1.2rem;">No resumes found yet.</p>
            <a href="/create" style="color: var(--primary); text-decoration: none; margin-top: 1rem; display: inline-block;">Start building now →</a>
        </div>`;
} else {
    resumes.forEach(resume => {
        dashboardBody += `
            <div class="card resume-card" data-id="${resume._id}" style="position: relative; overflow: hidden; transition: transform 0.3s ease, border-color 0.3s ease;">
                <div style="padding: 1.5rem;">
                    <div style="display: flex; justify-content: space-between; align-items: flex-start; margin-bottom: 1rem;">
                        <div class="nav-logo" style="width: 40px; height: 40px; border-radius: 10px;">
                            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2.5"><path d="M12 2L2 7l10 5 10-5-10-5zM2 17l10 5 10-5M2 12l10 5 10-5"/></svg>
                        </div>
                        <button onclick="confirmDelete('${resume._id}')" style="background: none; border: none; color: #ff4757; cursor: pointer; opacity: 0.5; transition: opacity 0.2s;" onmouseover="this.style.opacity=1" onmouseout="this.style.opacity=0.5">
                            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M3 6h18m-2 0v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6m3 0V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2"/></svg>
                        </button>
                    </div>
                    <h3 style="margin-bottom: 0.25rem; font-size: 1.2rem;">${resume.personal?.fullName || 'Untitled'}</h3>
                    <p style="font-size: 0.9rem; color: var(--primary); font-weight: 500; margin-bottom: 1rem;">${resume.targetRole || 'Software Professional'}</p>
                    
                    <div style="display: flex; align-items: center; gap: 0.5rem; color: var(--text-muted); font-size: 0.8rem; margin-bottom: 1.5rem;">
                        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="4" width="18" height="18" rx="2" ry="2"></rect><line x1="16" y1="2" x2="16" y2="6"></line><line x1="8" y1="2" x2="8" y2="6"></line><line x1="3" y1="10" x2="21" y2="10"></line></svg>
                        ${new Date(resume.createdAt).toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' })}
                    </div>

                    <div style="display: flex; gap: 0.8rem;">
                        <a href="/preview?id=${resume._id}" class="btn-hero" style="flex: 1; padding: 0.6rem; font-size: 0.85rem; background: var(--bg-card); border: 1px solid var(--border); color: var(--text);">
                            View
                        </a>
                        <button onclick="downloadDocx('${resume._id}')" class="btn-hero" style="flex: 1; padding: 0.6rem; font-size: 0.85rem;">
                            Download
                        </button>
                    </div>
                </div>
            </div>`;
    });
}
dashboardBody += `</div></div>`;
%>

<%- include('layout', { 
    title: "My Resumes | ResumeAI",
    body: dashboardBody,
    scripts: `
    <script>
    async function confirmDelete(id) {
        if (confirm('Are you sure you want to delete this resume?')) {
            try {
                const response = await fetch(\`/api/resume/\${id}\`, { method: 'DELETE' });
                if (response.ok) {
                    const card = document.querySelector(\`[data-id="\${id}"]\`);
                    card.style.transform = 'scale(0.8)';
                    card.style.opacity = '0';
                    setTimeout(() => card.remove(), 300);
                }
            } catch (err) {
                console.error(err);
                alert('Failed to delete resume');
            }
        }
    }

    async function downloadDocx(id) {
        try {
            const res = await fetch(\`/api/resume/\${id}\`);
            const resume = await res.json();
            
            const exportRes = await fetch('/api/resume/export-docx', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ resumeData: resume })
            });

            const blob = await exportRes.blob();
            const url = window.URL.createObjectURL(blob);
            const a = document.createElement('a');
            a.href = url;
            a.download = \`Resume_\${resume.personal.fullName.replace(/\\s+/g, '_')}.docx\`;
            document.body.appendChild(a);
            a.click();
            a.remove();
        } catch (err) {
            console.error(err);
            alert('Export failed');
        }
    }
    </script>
    `
}) %>
